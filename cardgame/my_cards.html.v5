<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>我的卡牌</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #0a0a1a; color: #fff; font-family: system-ui, sans-serif; padding: 20px; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.header h1 { color: #e94560; }
.tabs { display: flex; gap: 10px; margin-bottom: 20px; }
.tab { padding: 10px 20px; background: #1a1a2e; border: none; color: #aaa; cursor: pointer; border-radius: 5px; }
.tab.active { background: #e94560; color: #fff; }
.filter-row { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
.filter-row input, .filter-row select { padding: 8px; background: #1a1a2e; color: #fff; border: 1px solid #0f3460; border-radius: 5px; }
.card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); gap: 10px; max-height: 70vh; overflow-y: auto; padding: 10px; background: #0f0f20; border-radius: 10px; }
.album-card { border-radius: 8px; padding: 10px; text-align: center; cursor: pointer; transition: transform 0.2s; }
.album-card:hover { transform: scale(1.05); }
.album-card .card-thumb { width: 80px; height: 80px; margin: 0 auto 8px; border-radius: 5px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
.album-card .card-thumb img { max-width: 100%; max-height: 100%; object-fit: contain; }
.album-card h4 { font-size: 12px; margin: 5px 0; text-shadow: 0 1px 2px rgba(0,0,0,0.5); font-weight: bold; }
.album-card .count { font-size: 11px; color: #aaa; }
.album-card.locked { background: #333; cursor: default; }
.album-card.locked:hover { transform: none; }
.album-card.locked .card-thumb { background: inherit; }
.album-card.locked .count { color: #666; }
.album-card.locked h4 { color: inherit; }
/* 稀有度卡牌底色 - 静态CSS作为默认值 */
.album-card.rarity-1 { background: #0f3460; border: 1px solid #444; }
.album-card.rarity-2 { background: #0f3460; border: 1px solid #4caf50; }
.album-card.rarity-3 { background: #0f3460; border: 1px solid #2196f3; }
.album-card.rarity-4 { background: #0f3460; border: 1px solid #9c27b0; }
.album-card.rarity-5 { background: #0f3460; border: 1px solid #ffb300; }
.album-card.rarity-6 { background: #0f3460; border: 1px solid #f44336; }
/* 稀有度图片底色 - 静态CSS作为默认值 */
.album-card .card-thumb { background: #0f3460; }
.album-card.rarity-1 .card-thumb { background: transparent; }
.album-card.rarity-2 .card-thumb { background: #0f3460; }
.album-card.rarity-3 .card-thumb { background: #0f3460; }
.album-card.rarity-4 .card-thumb { background: #0f3460; }
.album-card.rarity-5 .card-thumb { background: #0f3460; }
.album-card.rarity-6 .card-thumb { background: #0f3460; }
/* 移动端适配 - 包括 iPad */
@media (max-width: 1024px) {
  body { padding: 10px; }
  .header { margin-bottom: 10px; }
  .tabs { gap: 6px; }
  .tab { padding: 8px 12px; font-size: 14px; }
  .filter-row { gap: 6px; }
  .filter-row input, .filter-row select { padding: 6px; font-size: 12px; }
  .card-grid { grid-template-columns: repeat(3, 1fr); gap: 6px; padding: 6px; max-height: calc(33vw * 4 + 40px); }
  .album-card { padding: 4px; }
  .album-card .card-thumb { width: 100%; aspect-ratio: 1; margin: 0 auto 2px; }
  .album-card h4 { font-size: 9px; margin: 1px 0; }
  .album-card .count { font-size: 8px; }
  .album-card img { width: 100%; height: auto; }
  .popup-content { padding: 15px; }
  .popup-container { flex-direction: column; }
  .popup-content .popup-image { flex: 0 0 280px; max-height: 400px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: transparent; }
  .popup-content .popup-image img { max-width: 100%; max-height: 400px; width: auto; height: auto; object-fit: contain; border-radius: 10px; cursor: pointer; }
  .popup-info { min-width: unset; }
  .popup-name { font-size: 18px; }
  .popup-rarity { font-size: 14px; }
  .stats-grid-2 { grid-template-columns: repeat(3, 1fr); gap: 5px; }
  .stats-grid-2 .stat-row { padding: 6px; background: transparent; }
}
  .stats-grid-2 .stat-label { font-size: 10px; }
  .stats-grid-2 .stat-value { font-size: 14px; }
  .popup-radar canvas { width: 200px; height: 200px; margin: 10px auto; }
}
.album-card .card-thumb img { max-width: 100%; max-height: 100%; object-fit: contain; }
.popup { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 1000; overflow-y: auto; justify-content: center; padding: 20px; }
.popup.show { display: flex; }
.popup-content { width: 95%; max-width: 750px; border-radius: 15px; padding: 30px; box-shadow: 0 15px 40px rgba(0,0,0,0.6); border: 2px solid rgba(233,69,96,0.3); position: relative; max-height: 90vh; overflow-y: auto; background: transparent; }
.popup-close { position: absolute; top: 15px; right: 15px; background: #e94560; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-size: 14px; }
.popup-content .popup-image { flex: 0 0 280px; height: 400px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: transparent; border-radius: 10px; }
.popup-content .popup-image img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; border-radius: 10px; cursor: pointer; }
.popup-info { flex: 1; min-width: 280px; display: flex; flex-direction: column; }
.popup-name { font-size: 24px; font-weight: bold; margin-bottom: 10px; }
.popup-rarity { font-size: 18px; margin-bottom: 10px; }
.popup-desc { color: #aaa; margin-bottom: 15px; line-height: 1.5; }
.popup-stats { margin-top: 20px; }
.popup-stats h4 { color: #e94560; margin-bottom: 10px; }
.stats-grid-2 { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; text-align: center; min-width: 0; }
.stats-grid-2 .stat-row { background: transparent; padding: 8px; border-radius: 5px; min-width: 0; }
.stats-grid-2 .stat-label { display: block; color: #aaa; font-size: 11px; margin-bottom: 4px; word-break: break-all; }
.stats-grid-2 .stat-value { display: block; font-weight: bold; font-size: 18px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
.popup-radar { margin-top: 20px; }
.image-popup { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 2000; justify-content: center; align-items: center; }
.image-popup.show { display: flex; }
.image-popup img { max-width: 95%; max-height: 95%; object-fit: contain; border-radius: 10px; }
.popup-radar canvas { width: 100%; max-width: 300px; height: 300px; margin: 0 auto; display: block; }
.popup-count { text-align: center; margin-top: 15px; font-size: 16px; color: #ffd700; }
.popup-buttons { display: flex; flex-direction: column; gap: 10px; margin-top: 20px; }
.popup-buttons .btn { padding: 12px; border: none; border-radius: 8px; cursor: pointer; font-size: 16px; }
.popup-buttons .btn-close { background: #0f3460; color: #fff; }
.popup-buttons .btn-fav { background: #e94560; color: #fff; }
.hidden { display: none; }
</style>
</head>
<body>
<div class="header">
<h1>我的卡牌</h1>
<a href="index.html" style="color:#aaa;">返回首页</a>
</div>
<div class="tabs">
<button class="tab active" onclick="switchTab('my')">我的卡牌</button>
<button class="tab" onclick="switchTab('album')">我的图鉴</button>
</div>
<div id="myFilters" class="filter-row">
<input type="text" id="filterName" placeholder="名字搜索..." oninput="applyFilter()">
<select id="filterRarity" onchange="applyFilter()"><option value="">全部稀有度</option></select>
<select id="filterFavorite" onchange="applyFilter()"><option value="">全部</option><option value="1">仅收藏</option></select>
</div>
<div id="albumFilters" class="filter-row hidden">
<input type="text" id="albumFilterName" placeholder="名字搜索..." oninput="applyAlbumFilter()">
<select id="albumFilterRarity" onchange="applyAlbumFilter()"><option value="">全部稀有度</option></select>
<select id="albumFilterOwned" onchange="applyAlbumFilter()"><option value="">全部</option><option value="owned">仅拥有</option><option value="unowned">未拥有</option></select>
</div>
<div id="myCardsGrid" class="card-grid"></div>
<div id="albumGrid" class="card-grid hidden"></div>

<div id="cardPopup" class="popup" onclick="closePopup()">
<div class="popup-content" onclick="event.stopPropagation()">
<span class="popup-close" onclick="closePopup()">关闭</span>
<div class="popup-container" style="display:flex;gap:20px;flex-wrap:wrap;">
<div class="popup-image">
<img id="popupImage" src="" onclick="showFullImage(this.src)">
</div>
<div class="popup-info">
<div id="popupName" class="popup-name"></div>
<div id="popupRarity" class="popup-rarity"></div>
<p id="popupDesc" class="popup-desc"></p>
<div class="popup-stats" id="myCardStats">
<div id="myCardStatsBox"></div>
</div>
<div class="popup-stats" id="albumStats">
<div class="stats-grid-2" id="albumStatsBox"></div>
</div>
<div class="popup-radar" id="albumRadar">
<canvas id="radarCanvas"></canvas>
</div>
<div class="image-popup" id="imagePopup" onclick="closeImagePopup()">
<img id="fullImage" src="">
</div>
</div>
<div id="popupCount" class="popup-count"></div>
<div class="popup-buttons" id="myCardButtons">
<button class="btn btn-fav" id="favoriteBtn" onclick="toggleFavorite()">添加收藏</button>
<button class="btn btn-close" onclick="closePopup()">关闭</button>
</div>
<div class="popup-buttons" id="albumButtons">
<button class="btn btn-close" onclick="closePopup()">关闭</button>
</div>
</div>
</div>
</div>
</div>

<script>
var userId = null;
var currentView = 'my';
var myCards = {};
var allCards = [];
var rarityConfig = [];
var rarityNames = ['', '普通', '稀有', '杰出', '史诗', '传说', '远古'];

// 加载稀有度配置（从数据库）
function loadRarityConfig() {
    console.log('开始加载稀有度配置...');
    return fetch('game_api.php?action=get_rarity')
        .then(function(r) { return r.json(); })
        .then(function(d) {
            console.log('get_rarity 返回:', d);
            if (d.rarity && d.rarity.length > 0) {
                rarityConfig = d.rarity;
                
                // 填充下拉列表（带星星）
                var raritySelect = document.getElementById('filterRarity');
                var albumRaritySelect = document.getElementById('albumFilterRarity');
                d.rarity.forEach(function(cfg) {
                    if (cfg.rarity && cfg.name) {
                        var stars = '⭐'.repeat(cfg.rarity);
                        var option1 = document.createElement('option');
                        option1.value = cfg.rarity;
                        option1.textContent = stars + ' ' + cfg.name;
                        raritySelect.appendChild(option1);
                        
                        var option2 = document.createElement('option');
                        option2.value = cfg.rarity;
                        option2.textContent = stars + ' ' + cfg.name;
                        albumRaritySelect.appendChild(option2);
                    }
                });
                
                // 收集颜色
                var rawColors = {};
                rarityConfig.forEach(function(cfg) {
                    console.log('稀有度配置:', cfg);
                    if (cfg.rarity && cfg.color) {
                        rawColors[cfg.rarity] = cfg.color;
                    }
                });
                // 构建颜色数组
                var bgColors = [''];
                var colors = [''];
                var maxRarity = 0;
                d.rarity.forEach(function(cfg) {
                    if (cfg.rarity) {
                        bgColors[cfg.rarity] = cfg.color || '#aaaaaa';
                        colors[cfg.rarity] = cfg.color || '#ffffff';
                        if (cfg.rarity > maxRarity) maxRarity = cfg.rarity;
                    }
                });
                // 淡化背景色 - 动态根据实际稀有度数量
                var litBgColors = [''];
                for (var i = 1; i <= maxRarity; i++) {
                    var c = bgColors[i];
                    console.log('稀有度' + i + '原始颜色:', c);
                    if (c && c.charAt(0) === '#') {
                        litBgColors[i] = lightenColor(c, 0.3);
                    } else {
                        litBgColors[i] = '#0f3460';
                    }
                }
                console.log('淡化背景色:', litBgColors);
                window.rarityBgColors = litBgColors;
                window.rarityColors = colors;
                console.log('设置完成 - rarityBgColors:', window.rarityBgColors, 'rarityColors:', window.rarityColors);
            }
        })
        .catch(function(e) {
            console.log('加载稀有度配置失败，使用默认', e);
        });
}

// 基础颜色
// 基础颜色 - 按稀有度(1-6)排列
var rarityBgColors = ['', '#aaaaaa', '#4caf50', '#2196f3', '#9c27b0', '#ff9800', '#f32b2b'];
var rarityColors = ['', '#ffffff', '#00e676', '#448aff', '#e040fb', '#ffab00', '#ff1744'];

// 淡化颜色函数 - 用于卡牌背景
function lightenColor(hex, factor) {
    if (!hex) return '#0f3460';
    var r = parseInt(hex.slice(1,3), 16);
    var g = parseInt(hex.slice(3,5), 16);
    var b = parseInt(hex.slice(5,7), 16);
    r = Math.round(r + (255 - r) * factor);
    g = Math.round(g + (255 - g) * factor);
    b = Math.round(b + (255 - b) * factor);
    return '#' + 
        (r < 16 ? '0' : '') + r.toString(16) + 
        (g < 16 ? '0' : '') + g.toString(16) + 
        (b < 16 ? '0' : '') + b.toString(16);
}
var filterState = { name: '', rarity: '', favorite: '' };
var albumFilterState = { name: '', rarity: '', owned: '' };
var currentCardInstanceId = null;
var maxStats = {hp:0, mp:0, attack:0, defense:0, agility:0};

// 根据全局最大属性计算颜色 - 百分比颜色
function getStatColor(value, statName) {
    var max = maxStats[statName];
    if (!max || max === 0) return '#aaa';
    var percent = (value / max) * 100;
    if (percent >= 100) return '#ff0000';  // 红色 100%
    if (percent >= 80) return '#ffd700';  // 黄色 80-99%
    if (percent >= 60) return '#9400d3';  // 紫色 60-79%
    if (percent >= 40) return '#4169e1';  // 蓝色 40-59%
    if (percent >= 20) return '#00ff00';  // 绿色 20-39%
    return '#ffffff';  // 白色 0-19%
}

// 从所有卡牌计算最大属性值
function calcMaxStats(cards) {
    if (!cards) return;
    cards.forEach(function(c) {
        if (c.baseStats.hp > maxStats.hp) maxStats.hp = c.baseStats.hp;
        if (c.baseStats.mp > maxStats.mp) maxStats.mp = c.baseStats.mp;
        if (c.baseStats.attack > maxStats.attack) maxStats.attack = c.baseStats.attack;
        if (c.baseStats.defense > maxStats.defense) maxStats.defense = c.baseStats.defense;
        if (c.baseStats.agility > maxStats.agility) maxStats.agility = c.baseStats.agility;
    });
}

function switchTab(tab) {
    currentView = tab;
    document.querySelectorAll('.tab').forEach(function(t, i) { t.classList.toggle('active', i === (tab === 'my' ? 0 : 1)); });
    document.getElementById('myFilters').classList.toggle('hidden', tab !== 'my');
    document.getElementById('albumFilters').classList.toggle('hidden', tab !== 'album');
    document.getElementById('myCardsGrid').classList.toggle('hidden', tab !== 'my');
    document.getElementById('albumGrid').classList.toggle('hidden', tab !== 'album');
    if (tab === 'my') loadMyCards();
    else loadAlbum();
}

function getImageUrl(card) {
    if (!card.image) return 'data/images/default.png';
    return card.image;
}

function getRarityColor(rarity) { return rarityColors[rarity] || '#fff'; }
function getRarityName(rarity) { return rarityNames[rarity] || rarity + '星'; }

function showFullImage(src) {
    document.getElementById('fullImage').src = src;
    document.getElementById('imagePopup').classList.add('show');
}

function closeImagePopup() {
    document.getElementById('imagePopup').classList.remove('show');
}

function loadMyCards() {
    if (!userId) return;
    fetch('game_api.php?action=get_my_cards&user_id=' + userId).then(function(r) { return r.json(); }).then(function(d) {
        if (d.code === 200 && d.cards) {
            myCards = {};
            d.cards.forEach(function(card) {
                card.baseStats = typeof card.base_stats === 'string' ? JSON.parse(card.base_stats) : card.base_stats;
                card.growthStats = typeof card.growth_stats === 'string' ? JSON.parse(card.growth_stats) : card.growth_stats;
                card.tags = typeof card.tags === 'string' ? JSON.parse(card.tags) : card.tags;
                myCards[card.instance_id] = card;
            });
            renderMyCards();
        }
    });
}

function loadAlbum() {
    if (!userId) return;
    fetch('game_api.php?action=get_all&user_id=' + userId).then(function(r) { return r.json(); }).then(function(d) {
        if (d.code === 200 && d.characters) {
            allCards = d.characters.map(function(card) {
                card.baseStats = typeof card.base_stats === 'string' ? JSON.parse(card.base_stats) : card.base_stats;
                card.growthStats = typeof card.growth_stats === 'string' ? JSON.parse(card.growth_stats) : card.growth_stats;
                card.tags = typeof card.tags === 'string' ? JSON.parse(card.tags) : card.tags;
                return card;
            });
            // 计算所有卡牌的最大属性值
            calcMaxStats(allCards);
            renderAlbum();
        }
    });
}

function renderMyCards() {
    var container = document.getElementById('myCardsGrid');
    var cards = Object.values(myCards);
    
    // 计算淡化背景色
    cards.forEach(function(card) {
        var bgColor = rarityBgColors[card.rarity] || '#666';
        card._bgColor = lightenColor(bgColor, 0.85);
    });
    
    cards = cards.filter(function(card) {
        if (filterState.name && !card.name.toLowerCase().includes(filterState.name)) return false;
        if (filterState.rarity && card.rarity !== parseInt(filterState.rarity)) return false;
        if (filterState.favorite && card.is_favorite != parseInt(filterState.favorite)) return false;
        return true;
    });
    
    cards.sort(function(a, b) { return b.rarity - a.rarity; });
    
    if (cards.length === 0) { container.innerHTML = '<div style="color:#aaa;grid-column:1/-1;padding:20px;">还没有卡牌，快去抽卡吧！</div>'; return; }
    
    var html = '';
    cards.forEach(function(card) {
        var stars = '⭐'.repeat(card.rarity);
        var level = card.level || 1;
        html += '<div class="album-card rarity-'+card.rarity+'" onclick="showMyCardPopup('+card.instance_id+')" style="background:'+card._bgColor+';">';
        html += '<div class="card-thumb" style="background:'+card._bgColor+';"><img src="'+getImageUrl(card)+'" alt="'+card.name+'"></div>';
        html += '<h4 style="color:'+rarityColors[card.rarity]+';">'+card.name+'</h4>';
        html += '<div style="font-size:10px;color:'+rarityColors[card.rarity]+';">'+stars+'</div>';
        html += '<div class="count" style="color:'+rarityColors[card.rarity]+';">Lv.'+level+'</div></div>';
    });
    container.innerHTML = html;
}

function renderAlbum() {
    var container = document.getElementById('albumGrid');
    var cards = allCards.filter(function(card) {
        if (albumFilterState.name && !card.name.toLowerCase().includes(albumFilterState.name)) return false;
        if (albumFilterState.rarity && card.rarity !== parseInt(albumFilterState.rarity)) return false;
        var isUnlocked = card.is_unlocked || 0;
        if (albumFilterState.owned === 'owned' && isUnlocked === 0) return false;
        if (albumFilterState.owned === 'unlocked' && isUnlocked === 0) return false;
        if (albumFilterState.owned === 'unowned' && isUnlocked === 1) return false;
        return true;
    });
    
    cards.sort(function(a, b) { return b.rarity - a.rarity; });
    
    // 计算淡化背景色
    cards.forEach(function(card) {
        var bgColor = rarityBgColors[card.rarity] || '#666';
        card._bgColor = lightenColor(bgColor, 0.85);
    });
    
    if (cards.length === 0) { container.innerHTML = '<div style="color:#aaa;grid-column:1/-1;padding:20px;">没有卡牌</div>'; return; }
    
    var html = '';
    cards.forEach(function(card) {
        var stars = '⭐'.repeat(card.rarity);
        var ownedCount = card.owned_count || 0;
        var isUnlocked = card.is_unlocked || 0;
        
        if (isUnlocked) {
            // 已解锁（图鉴点亮）- 使用淡化背景色
            html += '<div class="album-card rarity-'+card.rarity+'" onclick="showAlbumPopup('+card.id+')" style="background:'+card._bgColor+';">';
            html += '<div class="card-thumb" style="background:'+card._bgColor+';"><img src="'+getImageUrl(card)+'" alt="'+card.name+'"></div>';
            html += '<h4 style="color:'+rarityColors[card.rarity]+';">'+card.name+'</h4>';
            html += '<div style="font-size:10px;color:'+rarityColors[card.rarity]+';">'+stars+'</div>';
            if (ownedCount > 0) {
                html += '<div class="count">x'+ownedCount+'</div></div>';
            } else {
                html += '<div class="count" style="color:#666;">未拥有</div></div>';
            }
        } else {
            // 未解锁 - 使用 locked 样式
            html += '<div class="album-card locked">';
            html += '<div class="card-thumb"><img src="'+getImageUrl(card)+'" alt="'+card.name+'" style="filter:grayscale(100%) brightness(0.7);"></div>';
            html += '<h4 style="color:'+rarityColors[card.rarity]+';">'+card.name+'</h4>';
            html += '<div style="font-size:10px;color:'+rarityColors[card.rarity]+';">'+stars+'</div>';
            html += '<div class="count">未拥有</div></div>';
        }
    });
    container.innerHTML = html;
}

function applyFilter() {
    filterState.name = document.getElementById('filterName').value.trim().toLowerCase();
    filterState.rarity = document.getElementById('filterRarity').value;
    filterState.favorite = document.getElementById('filterFavorite').value;
    renderMyCards();
}

function applyAlbumFilter() {
    albumFilterState.name = document.getElementById('albumFilterName').value.trim().toLowerCase();
    albumFilterState.rarity = document.getElementById('albumFilterRarity').value;
    albumFilterState.owned = document.getElementById('albumFilterOwned').value;
    renderAlbum();
}

// ========== 我的卡牌详情弹窗 ==========
function showMyCardPopup(instanceId) {
    var card = myCards[instanceId];
    if (!card) return;
    
    currentCardInstanceId = instanceId;
    var level = card.level || 1;
    var exp = card.exp || 0;
    var baseStats = card.baseStats || {};
    var growthStats = card.growthStats || {};
    
    // 计算当前属性
    var currentStats = {
        hp: (baseStats.hp || 0) + (level - 1) * (growthStats.hp || 0),
        mp: (baseStats.mp || 0) + (level - 1) * (growthStats.mp || 0),
        attack: (baseStats.attack || 0) + (level - 1) * (growthStats.attack || 0),
        defense: (baseStats.defense || 0) + (level - 1) * (growthStats.defense || 0),
        agility: (baseStats.agility || 0) + (level - 1) * (growthStats.agility || 0)
    };
    
    // 动态字体大小（取最大值的位数）
    var statValues = [baseStats.hp||0, baseStats.mp||0, baseStats.attack||0, baseStats.defense||0, baseStats.agility||0, currentStats.hp, currentStats.mp, currentStats.attack, currentStats.defense, currentStats.agility];
    var maxValue = Math.max.apply(null, statValues);
    var fontSize;
    if (maxValue >= 100000) fontSize = '10px';
    else if (maxValue >= 10000) fontSize = '11px';
    else if (maxValue >= 1000) fontSize = '12px';
    else if (maxValue >= 100) fontSize = '14px';
    else fontSize = '16px';
    
    document.getElementById('popupImage').src = getImageUrl(card);
    document.getElementById('popupName').textContent = card.name + ' Lv.' + level;
    document.getElementById('popupName').style.color = rarityColors[card.rarity];
    document.getElementById('popupRarity').innerHTML =  '⭐'.repeat(card.rarity) + ' <span style="color:'+rarityColors[card.rarity]+'">' + rarityNames[card.rarity] + '</span>' + 
        '<div style="color:#888;font-size:14px;margin:5px 0;">经验：' + exp + '</div>';
    // 移除描述文字（我的卡牌弹窗不显示）
    
    // 显示卡牌详情的两个属性块
    document.getElementById('myCardStats').classList.remove('hidden');
    document.getElementById('myCardStatsBox').innerHTML = 
        '<div style="margin-bottom:20px;clear:both;">' +
        '<h4 style="color:#aaa;margin:10px 0 5px;">📊 基础属性</h4>' +
        '<div class="stats-grid-2" style="font-size:'+fontSize+';">' +
        '<div class="stat-row"><span class="stat-label">HP</span><span class="stat-value" style="font-size:'+fontSize+';">'+(baseStats.hp||0)+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">MP</span><span class="stat-value" style="font-size:'+fontSize+';">'+(baseStats.mp||0)+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">攻击</span><span class="stat-value" style="font-size:'+fontSize+';">'+(baseStats.attack||0)+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">防御</span><span class="stat-value" style="font-size:'+fontSize+';">'+(baseStats.defense||0)+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">敏捷</span><span class="stat-value" style="font-size:'+fontSize+';">'+(baseStats.agility||0)+'</span></div>' +
        '</div>' +
        '</div>' +
        '<div style="clear:both;">' +
        '<h4 style="color:#e94560;margin:15px 0 5px;">📊 当前属性</h4>' +
        '<div class="stats-grid-2" style="font-size:'+fontSize+';">' +
        '<div class="stat-row"><span class="stat-label">HP</span><span class="stat-value" style="color:#ffd700;font-size:'+fontSize+';">'+currentStats.hp+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">MP</span><span class="stat-value" style="color:#ffd700;font-size:'+fontSize+';">'+currentStats.mp+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">攻击</span><span class="stat-value" style="color:#ffd700;font-size:'+fontSize+';">'+currentStats.attack+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">防御</span><span class="stat-value" style="color:#ffd700;font-size:'+fontSize+';">'+currentStats.defense+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">敏捷</span><span class="stat-value" style="color:#ffd700;font-size:'+fontSize+';">'+currentStats.agility+'</span></div>' +
        '</div>' +
        '</div>';
    
    // 显示收藏按钮
    document.getElementById('myCardButtons').classList.remove('hidden');
    document.getElementById('favoriteBtn').textContent = card.is_favorite ? '移除收藏' : '添加收藏';
    
    // 隐藏图鉴相关内容
    document.getElementById('albumStats').classList.add('hidden');
    document.getElementById('albumRadar').classList.add('hidden');
    document.getElementById('albumButtons').classList.add('hidden');
    document.getElementById('popupCount').classList.add('hidden');
    
    document.getElementById('cardPopup').classList.add('show');
}

// ========== 图鉴详情弹窗 ==========
function showAlbumPopup(cardId) {
    var card = allCards.find(function(c) { return c.id === cardId; });
    if (!card) return;
    
    var baseStats = card.baseStats || {};
    var ownedCount = card.owned_count || 0;
    
    // 计算属性值中的最大值，用于动态字体大小（确保能显示下）
    var statValues = [baseStats.hp||0, baseStats.mp||0, baseStats.attack||0, baseStats.defense||0, baseStats.agility||0];
    var maxValue = Math.max.apply(null, statValues);
    // 根据最大值确定字体大小：值越大字体越小
    var fontSize;
    if (maxValue >= 100000) fontSize = '10px';  // 5位数
    else if (maxValue >= 10000) fontSize = '11px';  // 4位数
    else if (maxValue >= 1000) fontSize = '12px';  // 3位数
    else if (maxValue >= 100) fontSize = '14px';  // 2位数
    else fontSize = '16px';  // 1位数
    
    document.getElementById('popupImage').src = getImageUrl(card);
    document.getElementById('popupName').textContent = card.name;
    document.getElementById('popupName').style.color = rarityColors[card.rarity];
    document.getElementById('popupRarity').innerHTML =  '⭐'.repeat(card.rarity) + ' <span style="color:'+rarityColors[card.rarity]+'">' + rarityNames[card.rarity] + '</span>';
    document.getElementById('popupDesc').textContent = card.description || '';
    
    // 显示图鉴的基础属性（带颜色和动态字体大小）
    document.getElementById('albumStats').classList.remove('hidden');
    document.getElementById('albumStatsBox').innerHTML = 
        '<div class="stat-row"><span class="stat-label">HP</span><span class="stat-value" style="color:'+getStatColor(baseStats.hp, 'hp')+';font-size:'+fontSize+'">'+(baseStats.hp||0)+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">MP</span><span class="stat-value" style="color:'+getStatColor(baseStats.mp, 'mp')+';font-size:'+fontSize+'">'+(baseStats.mp||0)+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">攻击</span><span class="stat-value" style="color:'+getStatColor(baseStats.attack, 'attack')+';font-size:'+fontSize+'">'+(baseStats.attack||0)+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">防御</span><span class="stat-value" style="color:'+getStatColor(baseStats.defense, 'defense')+';font-size:'+fontSize+'">'+(baseStats.defense||0)+'</span></div>' +
        '<div class="stat-row"><span class="stat-label">敏捷</span><span class="stat-value" style="color:'+getStatColor(baseStats.agility, 'agility')+';font-size:'+fontSize+'">'+(baseStats.agility||0)+'</span></div>';
    
    // 显示持有数量
    document.getElementById('popupCount').classList.remove('hidden');
    document.getElementById('popupCount').textContent = ownedCount > 0 ? '持有: ' + ownedCount + ' 张' : '未拥有';
    
    // 隐藏卡牌详情相关内容，显示图鉴相关内容
    document.getElementById('myCardStats').classList.add('hidden');
    document.getElementById('myCardButtons').classList.add('hidden');
    document.getElementById('albumRadar').classList.remove('hidden');
    document.getElementById('albumButtons').classList.remove('hidden');
    
    document.getElementById('cardPopup').classList.add('show');
    setTimeout(function() { drawRadar(card); }, 100);
}

function drawRadar(card) {
    var canvas = document.getElementById('radarCanvas');
    var ctx = canvas.getContext('2d');
    var w = canvas.width = canvas.offsetWidth;
    var h = canvas.height = canvas.offsetHeight;
    var cx = w / 2;
    var cy = h / 2;
    var r = Math.min(w, h) / 2 - 30;
    var labels = ['HP', 'MP', '攻击', '防御', '敏捷'];
    var baseStats = card.baseStats || {};
    var stats = [
        maxStats.hp > 0 ? Math.round(baseStats.hp / maxStats.hp * 100) : 0,
        maxStats.mp > 0 ? Math.round(baseStats.mp / maxStats.mp * 100) : 0,
        maxStats.attack > 0 ? Math.round(baseStats.attack / maxStats.attack * 100) : 0,
        maxStats.defense > 0 ? Math.round(baseStats.defense / maxStats.defense * 100) : 0,
        maxStats.agility > 0 ? Math.round(baseStats.agility / maxStats.agility * 100) : 0
    ];
    var maxVal = 100;
    var angleStep = (Math.PI * 2) / 5;
    ctx.clearRect(0, 0, w, h);
    // 画背景圆
    for (var i = 1; i <= 5; i++) {
        ctx.beginPath();
        ctx.arc(cx, cy, r * i / 5, 0, Math.PI * 2);
        ctx.strokeStyle = '#333';
        ctx.stroke();
    }
    // 画轴线
    for (var i = 0; i < 5; i++) {
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        var angle = i * angleStep - Math.PI / 2;
        ctx.lineTo(cx + Math.cos(angle) * r, cy + Math.sin(angle) * r);
        ctx.strokeStyle = '#333';
        ctx.stroke();
        // 标签
        ctx.fillStyle = '#aaa';
        ctx.font = '12px sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(labels[i], cx + Math.cos(angle) * (r + 20), cy + Math.sin(angle) * (r + 20));
    }
    // 画数据多边形
    ctx.beginPath();
    for (var i = 0; i < 5; i++) {
        var angle = i * angleStep - Math.PI / 2;
        var stat = stats[i] / 100 * r;
        var x = cx + Math.cos(angle) * stat;
        var y = cy + Math.sin(angle) * stat;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.fillStyle = 'rgba(233, 69, 96, 0.3)';
    ctx.fill();
    ctx.strokeStyle = '#e94560';
    ctx.lineWidth = 2;
    ctx.stroke();
}

function closePopup() {
    document.getElementById('cardPopup').classList.remove('show');
}

function toggleFavorite() {
    if (!currentCardInstanceId) return;
    var card = myCards[currentCardInstanceId];
    if (!card) return;
    
    var newFav = card.is_favorite ? 0 : 1;
    fetch('game_api.php?action=update_favorite', {
        method: 'POST',
        body: JSON.stringify({ instance_id: currentCardInstanceId, is_favorite: newFav })
    }).then(function(r) { return r.json(); }).then(function(r) {
        if (r.code === 200) {
            card.is_favorite = newFav;
            document.getElementById('favoriteBtn').textContent = newFav ? '移除收藏' : '添加收藏';
        }
    });
}

// 初始化 - 从 localStorage 获取 user_id
var userId = localStorage.getItem('user_id');

if (!userId) {
    location.href = 'login.html';
} else {
    loadRarityConfig().then(function() {
        loadMyCards();
    });
}
</script>
</body>
</html>
